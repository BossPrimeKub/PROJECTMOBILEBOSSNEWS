<Page
    x:Class="MyUnoApp.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

<Grid>

<Grid.RowDefinitions>
<RowDefinition Height="*"/>
<RowDefinition Height="90"/>
</Grid.RowDefinitions>


<!-- CONTENT -->

<ScrollViewer Grid.Row="0">

<StackPanel Padding="20,40,20,20">

<TextBlock Text="March 8"
Foreground="Gray"
FontSize="16"/>

<TextBlock Text="PROFILE"
FontSize="48"
FontWeight="Bold"
Foreground="White"
Margin="0,10,0,20"/>


<!-- SUBSCRIPTION -->

<Border Background="#1E1E1E"
CornerRadius="12"
Padding="20"
Margin="0,0,0,20">

<StackPanel>

<TextBlock Text="Subscription: Free"
Foreground="White"
FontSize="20"/>

<TextBlock Text="Joined: 08 Mar 2026"
Foreground="White"
FontSize="20"
Margin="0,10,0,20"/>

<Button Content="Manage Account"
Background="Transparent"
BorderBrush="White"
BorderThickness="1"
Foreground="White"
CornerRadius="25"
Padding="20,10"
Margin="0,0,0,10"/>

<Button Content="Subscribe"
Background="#D7C296"
Foreground="Black"
CornerRadius="25"
Padding="20,10"/>

</StackPanel>

</Border>


<!-- MY ACTIVITY -->

<TextBlock Text="My Activity"
FontSize="32"
FontWeight="Bold"
Foreground="White"
Margin="0,0,0,10"/>


<Grid Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<TextBlock Text="Manage Sources &amp; Topics"
Foreground="White"
FontSize="20"/>

<FontIcon Glyph="&#xE72E;"
FontFamily="Segoe MDL2 Assets"
Foreground="Gray"
Grid.Column="1"/>

</Grid>


<Grid Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<TextBlock Text="Recently Viewed Stories"
Foreground="White"
FontSize="20"/>

<FontIcon Glyph="&#xE72A;"
FontFamily="Segoe MDL2 Assets"
Foreground="Gray"
Grid.Column="1"/>

</Grid>


<Grid Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<TextBlock Text="Saved Stories"
Foreground="White"
FontSize="20"/>

<FontIcon Glyph="&#xE72A;"
FontFamily="Segoe MDL2 Assets"
Foreground="Gray"
Grid.Column="1"/>

</Grid>



<!-- PROMOTIONS -->

<TextBlock Text="Promotions"
FontSize="32"
FontWeight="Bold"
Foreground="White"
Margin="0,30,0,10"/>


<TextBlock Text="Redeem Offer Code"
Foreground="White"
FontSize="20"
Margin="0,10,0,0"/>

<TextBlock Text="If you received a promotional or referral code you can enter the code here"
Foreground="Gray"
FontSize="14"
Margin="0,0,0,10"/>


<TextBlock Text="Invite friends to Ground News"
Foreground="White"
FontSize="20"
Margin="0,10,0,0"/>

<TextBlock Text="Get 1 month Ground News Premium subscription FREE per referral"
Foreground="Gray"
FontSize="14"/>

</StackPanel>

</ScrollViewer>


<!-- NAVBAR -->

<Grid Grid.Row="1"
Background="#111111"
Padding="10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>


<!-- NEWS -->

<Grid Grid.Column="0" Tapped="GoNews">

<StackPanel HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE12B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="News"
FontSize="14"
Foreground="Gray"/>

</StackPanel>

</Grid>


<!-- DISCOVER -->

<Grid Grid.Column="1" Tapped="GoDiscover">

<StackPanel HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE721;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Discover"
FontSize="14"
Foreground="Gray"/>

</StackPanel>

</Grid>


<!-- ALERTS -->

<Grid Grid.Column="2" Tapped="GoAlerts">

<StackPanel HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE7ED;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Alerts"
FontSize="14"
Foreground="Gray"/>

</StackPanel>

</Grid>


<!-- PROFILE ACTIVE -->

<StackPanel Grid.Column="3"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE77B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="White"/>

<TextBlock Text="Profile"
FontSize="14"
Foreground="White"/>

</StackPanel>

</Grid>

</Grid>

</Page>