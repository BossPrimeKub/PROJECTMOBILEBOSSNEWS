<Page
    x:Class="MyUnoApp.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <StackPanel Padding="20,40,20,20">

                <TextBlock Text="March 09" Foreground="Gray" FontSize="16"/>
                <TextBlock Text="PROFILE" FontSize="48" FontWeight="Bold" Foreground="White" Margin="0,10,0,20"/>

                <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Subscription: Free" Foreground="White" FontSize="20"/>
                            <TextBlock Text="Joined: 09 Mar 2026" Foreground="White" FontSize="20" Margin="0,10,0,20"/>
                            <Button Content="Manage Account" Background="Transparent" BorderBrush="White" BorderThickness="1" Foreground="White" CornerRadius="25" Padding="20,10" Margin="0,0,0,10" HorizontalAlignment="Stretch"/>
                            <Button Content="Subscribe" Background="#D7C296" Foreground="Black" CornerRadius="25" Padding="20,10" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE730;" FontFamily="Segoe MDL2 Assets" Foreground="#D7C296" FontSize="60" VerticalAlignment="Top" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <TextBlock Text="My Activity" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,10,0,15"/>
                
                <Grid Margin="0,0,0,20" Tapped="GoManageSources" Background="Transparent">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Manage Sources &amp; Topics" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                    <FontIcon Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="Gray" FontSize="18" Grid.Column="1" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,20" Tapped="GoRecentlyViewed" Background="Transparent">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Recently Viewed Stories" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                    <FontIcon Glyph="&#xE72A;" FontFamily="Segoe MDL2 Assets" Foreground="Gray" FontSize="18" Grid.Column="1" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,20" Tapped="GoSavedStories" Background="Transparent">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Saved Stories" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                    <FontIcon Glyph="&#xE72A;" FontFamily="Segoe MDL2 Assets" Foreground="Gray" FontSize="18" Grid.Column="1" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="Promotions" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,20,0,15"/>
                
                <StackPanel Tapped="GoRedeemOffer" Background="Transparent" Margin="0,0,0,25">
                    <TextBlock Text="Redeem Offer Code" Foreground="White" FontSize="20"/>
                    <TextBlock Text="If you received a promotional or referral code you can enter the code here" 
                               Foreground="Gray" FontSize="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Tapped="GoInviteFriends" Background="Transparent" Margin="0,0,0,10">
                    <TextBlock Text="Invite friends to Ground News" Foreground="White" FontSize="20"/>
                    <TextBlock Text="Get 1 month Ground News Premium subscription FREE per referral" 
                               Foreground="Gray" FontSize="14" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Background="#111111" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Tapped="GoNews" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE12B;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="Gray"/>
                    <TextBlock Text="News" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Tapped="GoDiscover" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="Gray"/>
                    <TextBlock Text="Discover" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2" Tapped="GoAlerts" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="Gray"/>
                    <TextBlock Text="Alerts" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="3" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="White"/>
                    <TextBlock Text="Profile" FontSize="12" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>