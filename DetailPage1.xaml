<Page
    x:Class="MyUnoApp.DetailPage1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="20,20,20,20">

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Click="Back_Click" Background="Transparent" Foreground="White" Padding="0">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20">
                        <FontIcon Glyph="&#xE897;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="20"/>
                        <FontIcon Glyph="&#xE72D;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="20"/>
                        <FontIcon Glyph="&#xE712;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="20"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Ground Summary" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <FontIcon Glyph="&#xE70D;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" Foreground="White"/>
                </Grid>

                <Grid Margin="0,10,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    
                    <Border CornerRadius="8" Width="80" Height="80" VerticalAlignment="Top">
                        <Image Source="https://images.unsplash.com/photo-1585829365295-ab7cd400c167?ixlib=rb-4.0.3&amp;auto=format&amp;fit=crop&amp;w=200&amp;q=80"
                               Stretch="UniformToFill"/>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Margin="15,0,0,0" TextWrapping="Wrap" Foreground="White" FontSize="20" FontWeight="Bold"
                               Text="Toddler evacuated from Gaza with rare disease recovers from malnutrition in Italian hospital"/>
                </Grid>
                
                <Border Height="1" Background="#333333" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,15">
                    <TextBlock Text="Full Coverage" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <FontIcon Glyph="&#xE70E;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" Foreground="White"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="SortStatusText" Text="Sort: Suggested" FontWeight="SemiBold" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="SourceCountText" Text="2 Sources" Foreground="Gray" FontSize="14"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Background="Transparent" Padding="0" Click="OpenFilter_Click">
                        <StackPanel>
                            <FontIcon Glyph="&#xE8CB;" FontFamily="Segoe MDL2 Assets" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="Sort &amp; Filter" Foreground="Gray" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <ListView x:Name="SourcesList" SelectionMode="None" BorderThickness="0" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Ellipse Width="24" Height="24" Fill="#3E6FB3"/>
                                            <TextBlock Text="{Binding PublisherName}" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" FontSize="16"/>
                                        </StackPanel>
                                        <FontIcon Glyph="&#xE712;" FontFamily="Segoe MDL2 Assets" Foreground="Gray" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                                        <Border Background="{Binding BiasColor}" CornerRadius="4" Padding="6,2" BorderBrush="Gray" BorderThickness="{Binding BiasBorder}">
                                            <TextBlock Text="{Binding Bias}" FontSize="12" Foreground="{Binding BiasTextColor}" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#333333" CornerRadius="4" Padding="6,2" Visibility="{Binding LocalityVisibility}">
                                            <TextBlock Text="{Binding Locality}" FontSize="12" Foreground="White"/>
                                        </Border>
                                        <Border Background="#333333" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding Factuality}" FontSize="12" Foreground="White"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Headline}" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Foreground="White" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="14" LineHeight="20">
                                        <Run Text="{Binding Snippet}"/>
                                        <Run Text=" Full Article" FontWeight="Bold" Foreground="White" TextDecorations="Underline"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding TimeAgo}" Foreground="Gray" FontSize="12" Margin="0,15,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="SortFilterOverlay" Background="#111111" Visibility="Collapsed" Canvas.ZIndex="100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Padding="20">
                <Button Background="Transparent" Foreground="White" Padding="0" Click="CloseFilter_Click">
                    <FontIcon Glyph="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                </Button>
                <TextBlock Text="Sort &amp; Filter" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="20" Spacing="25">
                    
                    <StackPanel Spacing="10">
                        <TextBlock Text="Sort:" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <ComboBox x:Name="SortComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#333333">
                            <ComboBoxItem Content="Suggested"/>
                            <ComboBoxItem Content="Alphabetical"/>
                            <ComboBoxItem Content="Latest"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Height="1" Background="#333333"/>

                    <TextBlock Text="Filter:" FontSize="18" FontWeight="Bold" Foreground="White"/>

                    <StackPanel Spacing="15">
                        <TextBlock Text="Bias" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Show sources from specific sections of the political spectrum" FontSize="14" Foreground="Gray" TextWrapping="Wrap"/>
                        
                        <Grid><TextBlock Text="Left" Foreground="White" VerticalAlignment="Center"/><ToggleSwitch x:Name="FilterLeft" HorizontalAlignment="Right" OffContent="" OnContent=""/></Grid>
                        <Grid><TextBlock Text="Center" Foreground="White" VerticalAlignment="Center"/><ToggleSwitch x:Name="FilterCenter" IsOn="True" HorizontalAlignment="Right" OffContent="" OnContent=""/></Grid>
                        <Grid><TextBlock Text="Right" Foreground="White" VerticalAlignment="Center"/><ToggleSwitch x:Name="FilterRight" HorizontalAlignment="Right" OffContent="" OnContent=""/></Grid>
                    </StackPanel>

                    <StackPanel Spacing="15">
                        <TextBlock Text="Factuality" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Show sources with a specific factuality rating" FontSize="14" Foreground="Gray" TextWrapping="Wrap"/>
                        
                        <Grid><TextBlock Text="High" Foreground="White" VerticalAlignment="Center"/><ToggleSwitch x:Name="FilterHigh" HorizontalAlignment="Right" OffContent="" OnContent=""/></Grid>
                        <Grid><TextBlock Text="Very High" Foreground="White" VerticalAlignment="Center"/><ToggleSwitch x:Name="FilterVeryHigh" IsOn="True" HorizontalAlignment="Right" OffContent="" OnContent=""/></Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Background="#1A1A1A" Padding="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Content="Clear" Background="Transparent" Foreground="Gray" FontSize="16" VerticalAlignment="Center" Click="ClearFilter_Click"/>
                <Button x:Name="ShowResultsBtn" Grid.Column="1" Content="Show 2 result(s)" Background="#D7C296" Foreground="Black" FontSize="16" FontWeight="Bold" 
                        HorizontalAlignment="Stretch" CornerRadius="8" Padding="15" Margin="20,0,0,0" Click="ApplyFilter_Click"/>
            </Grid>
        </Grid>
        </Grid>
</Page>