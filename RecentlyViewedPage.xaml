<Page
    x:Class="MyUnoApp.RecentlyViewedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Grid Padding="10,40,10,10">
            <Button Click="GoBack" Background="Transparent" VerticalAlignment="Center" Padding="15">
                <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="18"/>
            </Button>
            <TextBlock Text="Recently Viewed Stories" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="15" Spacing="15">
                
                <Border Background="#1E1E1E" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8" Margin="0,0,10,0">
                            <Grid>
                                <TextBlock Text="Offbeat" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="New Zealand" Foreground="Gray" FontSize="12" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="Bag Containing Weed and Cash Accidentally Donated to a New Zealand Charity Shop" 
                                       Foreground="White" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="24"/>
                            <TextBlock Text="12 Sources • 1h ago" Foreground="Gray" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="8" Width="80" Height="80" VerticalAlignment="Top">
                            <Image Source="https://images.unsplash.com/photo-1585829365295-ab7cd400c167?w=200" Stretch="UniformToFill"/>
                        </Border>
                    </Grid>
                </Border>
                
                </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Background="#111111" BorderBrush="#222222" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Tapped="GoNews" Background="Transparent">
                <StackPanel VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE12B;" Foreground="Gray" FontSize="22"/>
                    <TextBlock Text="News" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Tapped="GoDiscover" Background="Transparent">
                <StackPanel VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE721;" Foreground="Gray" FontSize="22"/>
                    <TextBlock Text="Discover" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2" Tapped="GoAlerts" Background="Transparent">
                <StackPanel VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7ED;" Foreground="Gray" FontSize="22"/>
                    <TextBlock Text="Alerts" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="3" Tapped="GoProfile" Background="Transparent">
                <StackPanel VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE77B;" Foreground="White" FontSize="22"/>
                    <TextBlock Text="Profile" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>