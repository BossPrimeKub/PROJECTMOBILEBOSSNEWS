<Page
    x:Class="MyUnoApp.SavedStoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Grid Padding="10,40,10,10">
            <Button Click="GoBack" Background="Transparent" VerticalAlignment="Center" Padding="15">
                <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="18"/>
            </Button>
            <TextBlock Text="Saved Stories" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="25">
            <FontIcon Glyph="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="100" Foreground="#222222"/>
            <TextBlock Text="You have no saved stories to read later" 
                       Foreground="White" FontSize="22" FontWeight="SemiBold" 
                       TextAlignment="Center" TextWrapping="Wrap" Width="280"/>
        </StackPanel>

        <Grid Grid.Row="2" Background="#111111" BorderBrush="#222222" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Tapped="GoNews" Background="Transparent"><StackPanel VerticalAlignment="Center"><FontIcon Glyph="&#xE12B;" Foreground="Gray" FontSize="22"/><TextBlock Text="News" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/></StackPanel></Grid>
            <Grid Grid.Column="1" Tapped="GoDiscover" Background="Transparent"><StackPanel VerticalAlignment="Center"><FontIcon Glyph="&#xE721;" Foreground="Gray" FontSize="22"/><TextBlock Text="Discover" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/></StackPanel></Grid>
            <Grid Grid.Column="2" Tapped="GoAlerts" Background="Transparent"><StackPanel VerticalAlignment="Center"><FontIcon Glyph="&#xE7ED;" Foreground="Gray" FontSize="22"/><TextBlock Text="Alerts" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/></StackPanel></Grid>
            <Grid Grid.Column="3" Background="Transparent"><StackPanel VerticalAlignment="Center"><FontIcon Glyph="&#xE77B;" Foreground="White" FontSize="22"/><TextBlock Text="Profile" Foreground="White" FontSize="11" HorizontalAlignment="Center"/></StackPanel></Grid>
        </Grid>
    </Grid>
</Page>