<Page
    x:Class="MyUnoApp.DiscoverPageDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

<Grid>

<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
</Grid.RowDefinitions>


<!-- HEADER -->

<Grid Padding="20,40,20,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>


<Button Click="GoBack"
Background="#1E1E1E"
CornerRadius="25"
Width="44"
Height="44">

<FontIcon Glyph="&#xE72B;"
FontFamily="Segoe MDL2 Assets"
Foreground="White"/>

</Button>


<Button Grid.Column="2"
Background="#1E1E1E"
CornerRadius="25"
Width="44"
Height="44"
Margin="10,0">

<FontIcon Glyph="&#xE7ED;"
FontFamily="Segoe MDL2 Assets"
Foreground="White"/>

</Button>


<Button Grid.Column="3"
Background="#1E1E1E"
CornerRadius="25"
Width="44"
Height="44">

<FontIcon Glyph="&#xE712;"
FontFamily="Segoe MDL2 Assets"
Foreground="White"/>

</Button>

</Grid>


<!-- CONTENT -->

<ScrollViewer Grid.Row="1">

<StackPanel Padding="20">


<!-- TOPIC -->

<StackPanel Orientation="Horizontal" Spacing="15">

<Image
Width="80"
Height="80"
Stretch="Fill"
Source="https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/International_Women%27s_Day_Logo.svg/512px-International_Women%27s_Day_Logo.svg.png"/>

<TextBlock
Text="International Women's Day"
FontSize="28"
FontWeight="Bold"
Foreground="White"
VerticalAlignment="Center"/>

</StackPanel>


<!-- FOLLOW / SHARE -->

<Grid Margin="0,20">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>


<Button
Grid.Column="0"
Click="Follow_Click"
Background="White"
Foreground="Black"
CornerRadius="10"
Padding="10">

<StackPanel Orientation="Horizontal" Spacing="6">

<FontIcon Glyph="&#xE710;"
FontFamily="Segoe MDL2 Assets"/>

<TextBlock Text="Follow"/>

</StackPanel>

</Button>


<Button
Grid.Column="1"
Background="Transparent"
BorderBrush="White"
BorderThickness="1"
Foreground="White"
CornerRadius="10"
Padding="10"
Margin="10,0,0,0">

<StackPanel Orientation="Horizontal" Spacing="6">

<FontIcon Glyph="&#xE72D;"
FontFamily="Segoe MDL2 Assets"/>

<TextBlock Text="Share"/>

</StackPanel>

</Button>

</Grid>


<!-- NEWS CARD 1 -->

<Border
Background="#1E1E1E"
CornerRadius="20"
Padding="20"
Margin="0,10">

<StackPanel>

<TextBlock
Text="Women's Day marches in Brazil decry gender-based violence"
FontSize="22"
FontWeight="SemiBold"
Foreground="White"
TextWrapping="Wrap"/>

<TextBlock
Text="12 Sources • 10h ago"
Foreground="Gray"
Margin="0,10,0,0"/>

</StackPanel>

</Border>


<!-- NEWS CARD 2 -->

<Border
Background="#1E1E1E"
CornerRadius="20"
Padding="20"
Margin="0,10">

<Grid>

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="90"/>
</Grid.ColumnDefinitions>


<TextBlock
Text="Putin Health Fears Grow as Leaked Video Shows Him Coughing"
FontSize="22"
FontWeight="SemiBold"
Foreground="White"
TextWrapping="Wrap"/>


<Image
Grid.Column="1"
Height="80"
Width="80"
Stretch="Fill"
Source="https://upload.wikimedia.org/wikipedia/commons/8/8f/Vladimir_Putin_2024.jpg"/>

</Grid>

</Border>


</StackPanel>

</ScrollViewer>

</Grid>

</Page>