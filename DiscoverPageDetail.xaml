<Page
    x:Class="MyUnoApp.DiscoverPageDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/> </Grid.RowDefinitions>

        <Grid Padding="20,40,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Click="GoBack" Background="#1E1E1E" CornerRadius="25" Width="44" Height="44" Padding="0">
                <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="White"/>
            </Button>

            <Button Grid.Column="2" Background="#1E1E1E" CornerRadius="25" Width="44" Height="44" Margin="10,0" Padding="0">
                <FontIcon Glyph="&#xE7ED;" FontFamily="Segoe MDL2 Assets" Foreground="White"/>
            </Button>

            <Button Grid.Column="3" Background="#1E1E1E" CornerRadius="25" Width="44" Height="44" Padding="0">
                <FontIcon Glyph="&#xE712;" FontFamily="Segoe MDL2 Assets" Foreground="White"/>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="20">

                <StackPanel Orientation="Horizontal" Spacing="15">
                    <Border CornerRadius="12" Width="80" Height="80" Background="White">
                        <Image Stretch="UniformToFill" Source="https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/International_Women%27s_Day_Logo.svg/512px-International_Women%27s_Day_Logo.svg.png"/>
                    </Border>
                    <TextBlock Text="International Women's Day" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap" Width="220"/>
                </StackPanel>

                <Grid Margin="0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Click="Follow_Click" Background="White" Foreground="Black" CornerRadius="10" Padding="10" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets"/>
                            <TextBlock Text="Follow" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Grid.Column="1" Click="Share_Click" Background="Transparent" BorderBrush="White" BorderThickness="1" Foreground="White" CornerRadius="10" Padding="10" Margin="10,0,0,0" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE72D;" FontFamily="Segoe MDL2 Assets"/>
                            <TextBlock Text="Share" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Background="#1E1E1E" CornerRadius="20" Padding="20" Margin="0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Women's Day marches in Brazil decry gender-based violence" FontSize="20" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="12 Sources • 10h ago" Foreground="Gray" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1" CornerRadius="8" Width="80" Height="80" VerticalAlignment="Top">
                            <Image Stretch="UniformToFill" Source="http://googleusercontent.com/image_collection/image_retrieval/17293877848401694076_0"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="20" Padding="20" Margin="0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Putin Health Fears Grow as Leaked Video Shows Him Coughing" FontSize="20" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="24 Sources • 12h ago" Foreground="Gray" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1" CornerRadius="8" Width="80" Height="80" VerticalAlignment="Top">
                            <Image Stretch="UniformToFill" Source="https://upload.wikimedia.org/wikipedia/commons/8/8f/Vladimir_Putin_2024.jpg"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Background="#111111" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Tapped="GoNews">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE12B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="News" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Tapped="GoDiscover">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White"/>
                    <TextBlock Text="Discover" FontSize="14" Foreground="White"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2" Tapped="GoAlerts">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Alerts" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="3" Tapped="GoProfile">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Profile" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>
        </Grid>

    </Grid>
</Page>