<Page
    x:Class="MyUnoApp.AlertPageDetail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="20,40,20,20">

                <Button Content="← Back"
                        Click="Back_Click"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Image Source="https://images.unsplash.com/photo-1504711434969-e33886168f5c?ixlib=rb-1.2.1&amp;auto=format&amp;fit=crop&amp;w=200&amp;q=80"
                           Width="70"
                           Height="70"
                           Stretch="UniformToFill"/>

                    <TextBlock Grid.Column="1"
                               Margin="10,0,0,0"
                               Text="Iran attacks breach international law, Swiss Defence Minister says"
                               TextWrapping="Wrap"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>
                </Grid>

                <Grid Height="20" Margin="0,10,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#A3332E"/>
                    <Border Grid.Column="1" Background="#CCCCCC"/>
                    <Border Grid.Column="2" Background="#2E4DA3"/>
                </Grid>

                <StackPanel Spacing="12">
                    <TextBlock Foreground="White"
                               TextWrapping="Wrap"
                               FontSize="18"
                               Text="• Swiss Defence Minister Martin Pfister said the United States and Israel violated international law."/>

                    <TextBlock Foreground="White"
                               TextWrapping="Wrap"
                               FontSize="18"
                               Text="• Under the United Nations Charter the Swiss Federal Council considers the attack a violation."/>

                    <TextBlock Foreground="White"
                               TextWrapping="Wrap"
                               FontSize="18"
                               Text="• Pfister urged all parties to halt the fighting to protect civilians."/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>