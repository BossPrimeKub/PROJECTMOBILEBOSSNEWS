<Page
    x:Class="MyUnoApp.DiscoverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

<Grid>

<Grid.RowDefinitions>
<RowDefinition Height="*"/>
<RowDefinition Height="90"/>
</Grid.RowDefinitions>


<ScrollViewer>

<StackPanel Padding="20,40,20,20">

<TextBlock Text="March 9"
Foreground="Gray"
FontSize="16"/>

<TextBlock Text="DISCOVER"
FontSize="48"
FontWeight="Bold"
Foreground="White"
Margin="0,10,0,20"/>


<!-- SEARCH -->

<Border Background="#1E1E1E"
CornerRadius="30"
Padding="10"
Margin="0,0,0,20">

<StackPanel Orientation="Horizontal" Spacing="10">

<FontIcon Glyph="&#xE721;"
FontFamily="Segoe MDL2 Assets"
Foreground="Gray"
VerticalAlignment="Center"/>

<TextBox
x:Name="SearchBox"
PlaceholderText="Search"
Background="Transparent"
BorderThickness="0"
Foreground="White"
FontSize="18"
TextChanged="SearchBox_TextChanged"/>

</StackPanel>

</Border>


<!-- SUGGESTED -->

<TextBlock Text="Suggested"
FontSize="32"
FontWeight="Bold"
Foreground="White"
Margin="0,0,0,10"/>


<Grid x:Name="ItemAutomation" Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Ellipse Width="40" Height="40" Fill="#FFD700"/>

<TextBlock Grid.Column="1"
Text="Automation"
Foreground="White"
FontSize="18"
VerticalAlignment="Center"
Margin="10,0"/>

<TextBlock Grid.Column="2"
Text="+"
Foreground="White"
FontSize="24"/>

</Grid>


<Grid x:Name="ItemXalapa" Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Ellipse Width="40" Height="40" Fill="#22C55E"/>

<TextBlock Grid.Column="1"
Text="Xalapa"
Foreground="White"
FontSize="18"
VerticalAlignment="Center"
Margin="10,0"/>

<TextBlock Grid.Column="2"
Text="+"
Foreground="White"
FontSize="24"/>

</Grid>


<!-- TRENDING -->

<TextBlock Text="Trending"
FontSize="32"
FontWeight="Bold"
Foreground="White"
Margin="0,30,0,10"/>


<Grid x:Name="ItemWomen"
Margin="0,10"
Tapped="OpenInternational">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Ellipse Width="40" Height="40" Fill="#D7C296"/>

<TextBlock Grid.Column="1"
Text="International Women's Day"
Foreground="White"
FontSize="18"
VerticalAlignment="Center"
Margin="10,0"/>

<TextBlock Grid.Column="2"
Text="+"
Foreground="White"
FontSize="24"/>

</Grid>


<Grid x:Name="ItemKorea" Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Ellipse Width="40" Height="40" Fill="#22C55E"/>

<TextBlock Grid.Column="1"
Text="South Korea Economy"
Foreground="White"
FontSize="18"
VerticalAlignment="Center"
Margin="10,0"/>

<TextBlock Grid.Column="2"
Text="+"
Foreground="White"
FontSize="24"/>

</Grid>


<!-- POPULAR -->

<TextBlock Text="Popular"
FontSize="32"
FontWeight="Bold"
Foreground="White"
Margin="0,30,0,10"/>


<Grid x:Name="ItemRussia" Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Ellipse Width="40" Height="40" Fill="#3B82F6"/>

<TextBlock Grid.Column="1"
Text="Russia"
Foreground="White"
FontSize="18"
VerticalAlignment="Center"
Margin="10,0"/>

<TextBlock Grid.Column="2"
Text="+"
Foreground="White"
FontSize="24"/>

</Grid>


<Grid x:Name="ItemTaiwan" Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Ellipse Width="40" Height="40" Fill="#EF4444"/>

<TextBlock Grid.Column="1"
Text="Taiwan"
Foreground="White"
FontSize="18"
VerticalAlignment="Center"
Margin="10,0"/>

<TextBlock Grid.Column="2"
Text="+"
Foreground="White"
FontSize="24"/>

</Grid>

</StackPanel>

</ScrollViewer>


<!-- NAVBAR -->

<Grid Grid.Row="1"
Background="#111111"
Padding="10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>


<Grid Grid.Column="0" Tapped="GoNews">

<StackPanel HorizontalAlignment="Center" Spacing="4">

<FontIcon Glyph="&#xE12B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="News" Foreground="Gray"/>

</StackPanel>

</Grid>


<StackPanel Grid.Column="1"
HorizontalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE721;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="White"/>

<TextBlock Text="Discover" Foreground="White"/>

</StackPanel>


<Grid Grid.Column="2" Tapped="GoAlerts">

<StackPanel HorizontalAlignment="Center" Spacing="4">

<FontIcon Glyph="&#xE7ED;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Alerts" Foreground="Gray"/>

</StackPanel>

</Grid>


<Grid Grid.Column="3" Tapped="GoProfile">

<StackPanel HorizontalAlignment="Center" Spacing="4">

<FontIcon Glyph="&#xE77B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Profile" Foreground="Gray"/>

</StackPanel>

</Grid>

</Grid>

</Grid>

</Page>