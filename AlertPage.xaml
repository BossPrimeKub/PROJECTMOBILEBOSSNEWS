<Page
    x:Class="MyUnoApp.AlertPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <StackPanel Padding="20,40,20,20">
                <TextBlock Text="March 8" Foreground="Gray" FontSize="16"/>
                <TextBlock Text="ALERTS" FontSize="48" FontWeight="Bold" Foreground="White" Margin="0,10,0,20"/>

                <ListView x:Name="AlertsList" SelectionMode="None" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <SwipeControl Margin="0,0,0,15">
                                <SwipeControl.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem Text="Share" Background="#2E4DA3" Invoked="Share_Invoked">
                                            <SwipeItem.IconSource>
                                                <SymbolIconSource Symbol="Share"/>
                                            </SwipeItem.IconSource>
                                        </SwipeItem>
                                        <SwipeItem Text="Delete" Background="#E81123" Invoked="Delete_Invoked">
                                            <SwipeItem.IconSource>
                                                <SymbolIconSource Symbol="Delete"/>
                                            </SwipeItem.IconSource>
                                        </SwipeItem>
                                    </SwipeItems>
                                </SwipeControl.RightItems>

                                <Border Background="#1E1E1E" CornerRadius="12" Padding="15" Tapped="OpenAlert">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <Border CornerRadius="8" Width="70" Height="70" VerticalAlignment="Top">
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                            <TextBlock Text="{Binding Time}" Foreground="Gray" FontSize="14"/>
                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </SwipeControl>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Background="#111111" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Tapped="GoNews">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE12B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="News" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Column="1" Tapped="GoDiscover">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Discover" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                <FontIcon Glyph="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White"/>
                <TextBlock Text="Alerts" FontSize="14" Foreground="White"/>
            </StackPanel>
            <Grid Grid.Column="3" Tapped="GoProfile">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Profile" FontSize="14" Foreground="Gray"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>