<Page
    x:Class="MyUnoApp.AlertPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

<Grid>

<Grid.RowDefinitions>
<RowDefinition Height="*"/>
<RowDefinition Height="90"/>
</Grid.RowDefinitions>


<!-- CONTENT -->

<ScrollViewer Grid.Row="0">

<Grid Padding="20,40,20,20">

<StackPanel>

<TextBlock Text="March 8"
           Foreground="Gray"
           FontSize="16"/>

<TextBlock Text="ALERTS"
           FontSize="48"
           FontWeight="Bold"
           Foreground="White"
           Margin="0,10,0,20"/>

<Border Background="#1E1E1E"
        CornerRadius="12"
        Padding="10"
        Tapped="OpenAlert">

<Grid>

<Grid.ColumnDefinitions>
<ColumnDefinition Width="80"/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>

<Image Source="Assets/news.jpg"
       Width="70"
       Height="70"
       Stretch="Fill"/>

<StackPanel Grid.Column="1"
            Margin="10,0,0,0">

<TextBlock Text="8 มี.ค. 2026 19:06"
           Foreground="Gray"
           FontSize="14"/>

<TextBlock Text="Iran attacks breach international law, Swiss Defence Minister says"
           TextWrapping="Wrap"
           Foreground="White"
           FontSize="18"/>

</StackPanel>

</Grid>

</Border>

</StackPanel>

</Grid>

</ScrollViewer>


<!-- NAVBAR -->

<Grid Grid.Row="1"
Background="#111111"
Padding="10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>


<!-- NEWS -->

<Grid Grid.Column="0"
Tapped="GoNews">

<StackPanel HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE12B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="News"
FontSize="14"
Foreground="Gray"/>

</StackPanel>

</Grid>


<!-- DISCOVER -->

<StackPanel Grid.Column="1"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE721;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Discover"
FontSize="14"
Foreground="Gray"/>

</StackPanel>


<!-- ALERTS (active) -->

<StackPanel Grid.Column="2"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE7ED;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="White"/>

<TextBlock Text="Alerts"
FontSize="14"
Foreground="White"/>

</StackPanel>


<!-- PROFILE -->

<StackPanel Grid.Column="3"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE77B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Profile"
FontSize="14"
Foreground="Gray"/>

</StackPanel>

</Grid>

</Grid>

</Page>