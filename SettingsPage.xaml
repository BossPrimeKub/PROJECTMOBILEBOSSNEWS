<Page
    x:Class="MyUnoApp.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid Padding="20,50,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="10" Margin="0,0,0,30">
            <TextBlock Text="Show me less..." FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Which topics would you like to see less of in your news feed:" 
                       FontSize="16" Foreground="Gray" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="25" Margin="0,10,0,0">
                
                <Grid>
                    <TextBlock Text="Europe" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <ToggleSwitch HorizontalAlignment="Right" OffContent="" OnContent=""/>
                </Grid>

                <Grid>
                    <TextBlock Text="Evacuations" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <ToggleSwitch HorizontalAlignment="Right" IsOn="True" OffContent="" OnContent=""/>
                </Grid>

                <Grid>
                    <TextBlock Text="Middle East Politics" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <ToggleSwitch HorizontalAlignment="Right" OffContent="" OnContent=""/>
                </Grid>

                <Grid>
                    <TextBlock Text="Middle East" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <ToggleSwitch HorizontalAlignment="Right" IsOn="True" OffContent="" OnContent=""/>
                </Grid>

                <Grid>
                    <TextBlock Text="Asia" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <ToggleSwitch HorizontalAlignment="Right" OffContent="" OnContent=""/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Spacing="10" Margin="0,20,0,0">
            <Button Content="Save" Background="White" Foreground="Black" FontSize="16" FontWeight="Bold" 
                    HorizontalAlignment="Stretch" CornerRadius="8" Padding="15" Click="Save_Click"/>
            <Button Content="Cancel" Background="Transparent" Foreground="White" FontSize="16" FontWeight="SemiBold"
                    HorizontalAlignment="Stretch" Padding="15" Click="Cancel_Click"/>
        </StackPanel>

    </Grid>
</Page>