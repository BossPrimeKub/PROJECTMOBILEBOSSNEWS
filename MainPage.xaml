<Page
    x:Class="MyUnoApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Grid Padding="20,40,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="September 06" FontSize="16" Foreground="Gray"/>
                <TextBlock Text="Boss News" FontSize="36" FontWeight="Bold" Foreground="White"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="10">
                <Button Width="44" Height="44" Background="#D6C49B" CornerRadius="22">
                    <FontIcon Glyph="&#xE707;" FontFamily="Segoe MDL2 Assets"/>
                </Button>
                <Button Width="44" Height="44" Background="#2A2A2A" CornerRadius="22">
                    <FontIcon Glyph="&#xE71C;" FontFamily="Segoe MDL2 Assets" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer>
                <StackPanel Padding="20">

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Background="White" Foreground="Black" Padding="18,10" CornerRadius="12">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A5;" FontFamily="Segoe MDL2 Assets"/>
                                <TextBlock Text="Top International"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#2A2A2A" Padding="18,10" CornerRadius="12">
                            <TextBlock Text="For You" Foreground="White"/>
                        </Button>
                        <Button Background="#2A2A2A" Padding="18,10" CornerRadius="12">
                            <TextBlock Text="Blindspot" Foreground="White"/>
                        </Button>
                    </StackPanel>

                    <Border Background="#D7C296" CornerRadius="12" Padding="15" Margin="0,20,0,20" Tapped="Headline_Tapped">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="10" Height="80" Width="100" Background="#A0A0A0">
                                <Image Source="https://images.unsplash.com/photo-1518057111178-44a106bad636?ixlib=rb-4.0.3&amp;auto=format&amp;fit=crop&amp;w=300&amp;q=80" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Grid.Column="1" Margin="15,0,0,0" TextWrapping="Wrap" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="Anthropic Agrees to Pay Authors at Least $1.5 Billion in AI Copyright Settlement"/>
                        </Grid>
                    </Border>

                    <ListView x:Name="NewsList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="NewsList_ItemClick" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="20" Padding="20" Margin="0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Category}" FontSize="16" Foreground="Gray"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Location}" Foreground="Gray"/>
                                        </Grid>
                                        <Grid Margin="0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="White"/>
                                            <Border Grid.Column="1" CornerRadius="10" Height="80" Width="80" Background="#333333">
                                                <Image Source="{Binding Image}" Stretch="UniformToFill"/>
                                            </Border>
                                        </Grid>
                                        <Grid Height="6" Margin="0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#3E6FB3"/>
                                            <Border Grid.Column="1" Background="#B23E3E"/>
                                        </Grid>

                                        <Grid Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Sources}" Foreground="Gray" VerticalAlignment="Center"/>
                                            
                                            <Button HorizontalAlignment="Right" Background="Transparent" Padding="0" BorderThickness="0">
                                                <FontIcon Glyph="&#xE712;" FontFamily="Segoe MDL2 Assets" Foreground="Gray"/>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Share" Icon="Share" Click="MenuShare_Click"/>
                                                        <MenuFlyoutItem Text="Show me less content like this" Click="MenuShowLess_Click"/>
                                                        <MenuFlyoutItem Text="Save for later" Icon="Save"/>
                                                        <MenuFlyoutItem Text="Report an issue" Icon="Flag"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                        
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="RestoreBanner" Background="#2A2A2A" CornerRadius="8" Padding="15,12" Margin="20,0,20,15" 
                    VerticalAlignment="Bottom" Visibility="Collapsed">
                <Grid>
                    <TextBlock Text="Restore topics in settings" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                    <Button Content="OPEN" Foreground="White" Background="Transparent" FontWeight="Bold" FontSize="14" 
                            HorizontalAlignment="Right" Padding="0" Click="RestoreOpen_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Background="#111111" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                <FontIcon Glyph="&#xE12B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="White"/>
                <TextBlock Text="News" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Tapped="Discover_Click">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Discover" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Tapped="Alerts_Click">
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Alerts" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Background="#D7C296" CornerRadius="12" Width="22" Height="22" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
            <Grid Grid.Column="3" Tapped="GoProfile">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="Gray"/>
                    <TextBlock Text="Profile" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>