<Page
    x:Class="MyUnoApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

<Grid>

<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
<RowDefinition Height="90"/>
</Grid.RowDefinitions>


<!-- HEADER -->

<Grid Padding="20,40,20,10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<StackPanel>

<TextBlock Text="September 06"
FontSize="16"
Foreground="Gray"/>

<TextBlock Text="Ground News"
FontSize="36"
FontWeight="Bold"
Foreground="White"/>

</StackPanel>

<StackPanel Orientation="Horizontal"
Grid.Column="1"
Spacing="10">

<Button Width="44"
Height="44"
Background="#D6C49B"
CornerRadius="22">

<FontIcon Glyph="&#xE707;"
FontFamily="Segoe MDL2 Assets"/>

</Button>

<Button Width="44"
Height="44"
Background="#2A2A2A"
CornerRadius="22">

<FontIcon Glyph="&#xE71C;"
FontFamily="Segoe MDL2 Assets"
Foreground="White"/>

</Button>

</StackPanel>

</Grid>


<!-- CONTENT -->

<ScrollViewer Grid.Row="1">

<StackPanel Padding="20">

<!-- TABS -->

<StackPanel Orientation="Horizontal" Spacing="10">

<Button Background="White"
Foreground="Black"
Padding="18,10"
CornerRadius="12">

<StackPanel Orientation="Horizontal" Spacing="6">

<FontIcon Glyph="&#xE8A5;"
FontFamily="Segoe MDL2 Assets"/>

<TextBlock Text="Top International"/>

</StackPanel>

</Button>

<Button Background="#2A2A2A"
Padding="18,10"
CornerRadius="12">

<TextBlock Text="For You"
Foreground="White"/>

</Button>

<Button Background="#2A2A2A"
Padding="18,10"
CornerRadius="12">

<TextBlock Text="Blindspot"
Foreground="White"/>

</Button>

</StackPanel>


<!-- HEADLINE -->

<Border Background="#D7C296"
CornerRadius="12"
Padding="15"
Margin="0,20,0,20">

<Grid>

<Grid.ColumnDefinitions>
<ColumnDefinition Width="100"/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>

<Border CornerRadius="10"
Height="80"
Width="100">

<Image Source="Assets/news.jpg"
Stretch="Fill"/>

</Border>

<TextBlock Grid.Column="1"
Margin="15,0,0,0"
TextWrapping="Wrap"
FontSize="20"
FontWeight="SemiBold"
Foreground="White"
Text="Anthropic Agrees to Pay Authors at Least $1.5 Billion in AI Copyright Settlement"/>

</Grid>

</Border>


<!-- NEWS LIST -->

<ListView x:Name="NewsList"
SelectionMode="None"
BorderThickness="0"
Background="Transparent">

<ListView.ItemTemplate>

<DataTemplate>

<Border Background="#1E1E1E"
CornerRadius="20"
Padding="20"
Margin="0,10">

<StackPanel>

<Grid>

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<TextBlock Text="{Binding Category}"
FontSize="16"
Foreground="Gray"/>

<TextBlock Grid.Column="1"
Text="{Binding Location}"
Foreground="Gray"/>

</Grid>

<Grid Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition Width="90"/>
</Grid.ColumnDefinitions>

<TextBlock Text="{Binding Title}"
FontSize="22"
FontWeight="SemiBold"
TextWrapping="Wrap"
Foreground="White"/>

<Border Grid.Column="1"
CornerRadius="10"
Height="80"
Width="80">

<Image Source="{Binding Image}"
Stretch="Fill"/>

</Border>

</Grid>

<Grid Height="6" Margin="0,10">

<Grid.ColumnDefinitions>
<ColumnDefinition Width="3*"/>
<ColumnDefinition Width="1*"/>
</Grid.ColumnDefinitions>

<Border Background="#3E6FB3"/>
<Border Grid.Column="1" Background="#B23E3E"/>

</Grid>

<TextBlock Text="{Binding Sources}" Foreground="Gray"/>

</StackPanel>

</Border>

</DataTemplate>

</ListView.ItemTemplate>

</ListView>

</StackPanel>

</ScrollViewer>


<!-- NAVBAR -->

<Grid Grid.Row="2"
Background="#111111"
Padding="10">

<Grid.ColumnDefinitions>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
<ColumnDefinition/>
</Grid.ColumnDefinitions>


<!-- NEWS -->

<StackPanel Grid.Column="0"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE12B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="White"/>

<TextBlock Text="News"
FontSize="14"
Foreground="White"
HorizontalAlignment="Center"/>

</StackPanel>


<!-- DISCOVER -->

<Grid Grid.Column="1"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Tapped="Discover_Click">

<StackPanel
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE721;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Discover"
FontSize="14"
Foreground="Gray"
HorizontalAlignment="Center"/>

</StackPanel>

</Grid>


<!-- ALERTS -->

<Grid Grid.Column="2"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Tapped="Alerts_Click">

<StackPanel HorizontalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE7ED;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Alerts"
FontSize="14"
Foreground="Gray"
HorizontalAlignment="Center"/>

</StackPanel>

<Border Background="#D7C296"
CornerRadius="12"
Width="22"
Height="22"
HorizontalAlignment="Right"
VerticalAlignment="Top">

<TextBlock Text="1"
HorizontalAlignment="Center"
VerticalAlignment="Center"
FontSize="11"
FontWeight="Bold"/>

</Border>

</Grid>


<!-- PROFILE -->

<Grid Grid.Column="3" Tapped="GoProfile">

<StackPanel
HorizontalAlignment="Center"
VerticalAlignment="Center"
Spacing="4">

<FontIcon Glyph="&#xE77B;"
FontFamily="Segoe MDL2 Assets"
FontSize="26"
Foreground="Gray"/>

<TextBlock Text="Profile"
FontSize="14"
Foreground="Gray"
HorizontalAlignment="Center"/>

</StackPanel>

</Grid>

</Grid>

</Grid>

</Page>